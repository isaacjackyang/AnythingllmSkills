{
  "mcpServers": {
    "filesystem": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-filesystem",
        "C:\\Users\\USER\\Downloads",
        "C:\\agent_sandbox"
      ]
    },
    "windows-mcp": {
      "command": "uvx",
      "args": [
        "--from",
        "git+https://github.com/CursorTouch/Windows-MCP",
        "windows-mcp"
      ]
    }
  }
}
